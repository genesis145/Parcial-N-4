<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <title>Registro de Usuario</title>

    <link rel="stylesheet" href="estilo.css">

</head>


<body>


<div class="contenedor">


    <h1>Crear Cuenta</h1>


    <form action="#" method="POST">


        <label>
            Nombre:
        </label>

        <input 
        type="text"
        name="nombre"
        placeholder="Ingrese su nombre"
        required
        minlength="3">


        <label>
            Correo electrónico:
        </label>

        <input 
        type="email"
        name="correo"
        placeholder="ejemplo@gmail.com"
        required>


        <label>
            Contraseña:
        </label>


        <input
        type="password"
        name="password"
        placeholder="Ingrese contraseña"
        required
        minlength="8">


        <button type="submit">
            Registrarse
        </button>


    </form>


</div>


</body>

</html>
